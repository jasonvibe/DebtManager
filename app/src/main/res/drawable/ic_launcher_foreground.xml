    <path
        android:pathData="M53,38 h20 a5,5 0 0 1 5,5 v22 a5,5 0 0 1 -5,5 h-20 a5,5 0 0 1 -5,-5 v-22 a5,5 0 0 1 5,-5 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="48"
                android:startY="38"
                android:endX="78"
                android:endY="70"
                android:type="linear">
                <item android:color="#10B981" android:offset="0.0" />
                <item android:color="#047857" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Ledger Card Bookmark Ribbon (Accent red/orange) -->
    <path
        android:pathData="M68,38 h4 v10 l-2,-2 l-2,2 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="68"
                android:startY="38"
                android:endX="72"
                android:endY="48"
                android:type="linear">
                <item android:color="#F87171" android:offset="0.0" />
                <item android:color="#DC2626" android:offset="1.0" />
            </gradient>
        </aapt:attr>
