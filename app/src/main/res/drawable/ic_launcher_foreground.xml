        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="28"
                android:startY="38"
                android:endX="60"
                android:endY="70"
                android:type="linear">
                <item android:color="#FCD34D" android:offset="0.0" />
                <item android:color="#D97706" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Coin Inner Detailed Rim -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.2"
        android:strokeAlpha="0.35"
        android:pathData="M44,54 m-12,0 a12,12 0,1 1,24 0 a12,12 0,1 1,-24 0" />

    <!-- Plus / Credit symbol in center of gold coin -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M44,48 L44,60 M38,54 L50,54" />

