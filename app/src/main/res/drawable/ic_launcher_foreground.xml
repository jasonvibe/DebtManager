    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- DROP SHADOW FOR COIN AND LEDGER CARD -->
    <path
        android:fillColor="#15000000"
        android:pathData="M46,56 m-16,0 a16,16 0,1 1,32 0 a16,16 0,1 1,-32 0" />
    <path
        android:fillColor="#20000000"
